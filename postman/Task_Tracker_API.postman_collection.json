    {
      "name": "Auth",
      "description": "Authentication requests. Register/login requests save access tokens automatically.",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{apiUrl}}/auth/register",
              "host": [
                "{{apiUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Register a normal USER account and save userAccessToken.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"user{{$timestamp}}@test.com\",\n  \"password\": \"password123\",\n  \"role\": \"USER\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 201 or 200\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.expect(json.success).to.eql(true);",
                  "",
                  "if (json.data && json.data.accessToken) {",
                  "    pm.environment.set(\"userAccessToken\", json.data.accessToken);",
                  "}",
                  "",
                  "if (json.data && json.data.user) {",
                  "    pm.environment.set(\"userId\", json.data.user.id);",
                  "    pm.environment.set(\"userEmail\", json.data.user.email);",
                  "}"
                ]
              }
            }
          ]
        },
